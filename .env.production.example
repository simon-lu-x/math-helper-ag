# 阿里云生产环境配置示例
# 复制此文件为 .env.production，填入真实值后构建前端

# 前端 OCR API 基础 URL（阿里云 FC HTTP 触发器地址 或 自定义域名）
# 格式示例: https://api.yourdomain.com
# 注意: 不要以 / 结尾
VITE_API_BASE=https://api.yourdomain.com

# Qwen OCR（可选，若前端直接调用 Qwen API 则填写）
VITE_QWEN_API_KEY=your-qwen-api-key-here

# Gemini API Key 仅供本地开发使用，生产环境由 FC 环境变量注入，前端不需要
# VITE_GEMINI_API_KEY=
